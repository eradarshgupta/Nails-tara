# ── REQUIRED: Supabase (database) ──────────────────────────────
# Get from https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── Admin credentials (change these!) ──────────────────────────
ADMIN_EMAIL=admin@taranails.com
ADMIN_PASSWORD=Tara@2024
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── OPTIONAL: Image uploads ─────────────────────────────────────
# Create a Blob store in Vercel dashboard → Storage → Blob → Create
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token

# ── OPTIONAL: Razorpay payments ────────────────────────────────
# Get keys from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
